# Copy this to .env.local for local dev, or set as Vercel Environment Variables

# Paste the full Firebase service account JSON here as a single-line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# A secret password that protects your developer portal
DEV_API_KEY=change-this-to-a-strong-secret-password
